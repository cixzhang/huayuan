{
  "name": "huayuan",
  "version": "1.0.0",
  "description": "A terminal garden game for learning Chinese and Vim",
  "type": "module",
  "bin": {
    "huayuan": "./bin/huayuan.js"
  },
  "files": [
    "bin/",
    "src/",
    "docs/"
  ],
  "scripts": {
